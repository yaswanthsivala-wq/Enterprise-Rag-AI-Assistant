# --- Flask -------------------------------------------------------------------
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# --- LLM provider (default: groq, free, no credit card) ----------------------
LLM_PROVIDER=groq
# Get a free key at https://console.groq.com  (starts with gsk_)
GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.3-70b-versatile      # or llama-3.1-8b-instant (faster)

# --- Optional: use IBM watsonx instead ---------------------------------------
# Requires: pip install -r requirements-watsonx.txt
# LLM_PROVIDER=watsonx
# IBM_API_KEY=your_api_key
# IBM_URL=https://us-south.ml.cloud.ibm.com
# IBM_PROJECT_ID=your_project_id

# --- Optional overrides ------------------------------------------------------
# UPLOAD_FOLDER=uploads
# VECTOR_DB=vector_store
# MAX_UPLOAD_MB=25
# WEB_CONCURRENCY=1
# PORT=8080
